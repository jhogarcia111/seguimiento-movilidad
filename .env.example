# Copia este archivo a .env.local (no commitear secretos)

NODE_ENV=development

# Neon / PostgreSQL (obligatorio)
DATABASE_URL=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require

JWT_SECRET=cambia_esto_en_produccion
JWT_EXPIRES_IN=7d

TWITTER_BEARER_TOKEN=

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@transitotito.com

FRONTEND_URL=http://localhost:4051

# Usuarios existentes promovidos a admin+activo al arrancar la app (lista separada por comas).
# Si no defines esta variable, por defecto se intenta promover el usuario "Jho".
# Para desactivar: BOOTSTRAP_ADMIN_USERNAMES=
# BOOTSTRAP_ADMIN_USERNAMES=Jho,otro_admin

# Secret usado por Vercel Cron Jobs para autenticar /api/cron/refresh-cache.
# Vercel lo agrega automáticamente como `Authorization: Bearer ${CRON_SECRET}`.
# En local puedes dejarlo vacío y se permite la ejecución sin auth para pruebas con curl.
# CRON_SECRET=genera_un_secret_largo_aleatorio

# Opcional: clave de DeepSeek para validación AI de blogposts en el scraping
# DEEPSEEK_API_KEY=

# Opcional: clave de Google Maps para geocoding de mayor precisión (default: Nominatim gratis)
# GOOGLE_MAPS_API_KEY=
