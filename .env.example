# Copia este archivo a .env.local (NO commitear)

# Entorno
NODE_ENV=development

# Neon / PostgreSQL (obligatorio)
# Dashboard Neon → Connection string → copiar (sslmode=require)
DATABASE_URL=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require

# JWT
JWT_SECRET=cambia_esto_en_produccion
JWT_EXPIRES_IN=7d

# Twitter / X API v2
TWITTER_BEARER_TOKEN=

# SMTP (Nodemailer) - opcional; si no se configura el envío de emails falla silenciosamente
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@transitotito.com

# URL pública del frontend (usada en links de emails). En desarrollo puede ser http://localhost:4051
FRONTEND_URL=http://localhost:4051

# Producción: orígenes adicionales permitidos (coma separada). No requerido en mismo dominio.
# ALLOWED_ORIGINS=https://tu-dominio.com,https://www.tu-dominio.com
