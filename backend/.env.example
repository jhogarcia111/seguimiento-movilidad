# Copia a .env y rellena (nunca subas .env al repositorio)

PORT=3051
NODE_ENV=development

# Neon / PostgreSQL (obligatorio)
# Dashboard Neon → Connection string → copiar (sslmode=require)
DATABASE_URL=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require

JWT_SECRET=cambia_esto_en_produccion
JWT_EXPIRES_IN=7d

# Producción: orígenes del frontend (coma separada). Opcional si usas *.vercel.app (ya permitido por código).
# ALLOWED_ORIGINS=https://tu-dominio.com,https://www.tu-dominio.com

# Opcional: Twitter, SMTP, etc. (ver EMAIL_CONFIG.md)
